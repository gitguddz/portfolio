------

<div id="title-container">
    
    <canvas id="title-canvas"></canvas>

    <div id="clock"></div>

</div>

<script>
  import * as THREE from 'three';
  import { FontLoader } from 'three/addons/loaders/FontLoader.js';
  import { TextGeometry } from 'three/addons/geometries/TextGeometry.js';

  function init() {
    const container = document.getElementById('title-container') as HTMLDivElement;
    const canvas = document.getElementById('title-canvas') as HTMLCanvasElement;

    const HEIGHT = 100;
    const WIDTH = container.offsetWidth || window.innerWidth;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(50, WIDTH / HEIGHT, 0.1, 1000);
    camera.position.z = 12;

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setClearColor(0x000000, 0);
    renderer.setSize(WIDTH, HEIGHT);
    renderer.setPixelRatio(window.devicePixelRatio);

    scene.add(new THREE.AmbientLight(0xffffff, 1));
    const key = new THREE.DirectionalLight(0xffffff, 1.5);
    key.position.set(0, 5, 10);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0x8888ff, 0.6);
    fill.position.set(0, -3, -10);
    scene.add(fill);

    const loader = new FontLoader();
    loader.load('/fonts/helvetiker_bold.typeface.json', (font) => {
      const group = new THREE.Group();
      const text = 'EPSTEIN ISLAND';
      const letterMeshes: THREE.Mesh[] = [];

      const CHAR_SIZE = 2.5;
      const CHAR_GAP = 0.12;
      const SPACE_WIDTH = 0.8;

      // Measure each character; treat spaces as a fixed width with no geometry
      const charWidths: number[] = Array.from(text).map((char) => {
        if (char === ' ') return SPACE_WIDTH;
        const geo = new TextGeometry(char, { font, size: CHAR_SIZE, depth: 0.4, curveSegments: 6, bevelEnabled: true, bevelThickness: 0.04, bevelSize: 0.03, bevelSegments: 3 });
        geo.computeBoundingBox();
        const w = geo.boundingBox!.max.x - geo.boundingBox!.min.x;
        geo.dispose();
        return w;
      });

      const totalWidth = charWidths.reduce((s, w) => s + w, 0) + CHAR_GAP * (text.length - 1);
      let offsetX = -totalWidth / 2;

      Array.from(text).forEach((char, i) => {
        if (char !== ' ') {
          const geo = new TextGeometry(char, { font, size: CHAR_SIZE, depth: 0.4, curveSegments: 6, bevelEnabled: true, bevelThickness: 0.04, bevelSize: 0.03, bevelSegments: 3 });
          const material = new THREE.MeshPhongMaterial({
            color: new THREE.Color().setHSL(i / text.length, 0.9, 0.55),
            shininess: 120,
            specular: 0x555555,
          });
          const mesh = new THREE.Mesh(geo, material);
          mesh.position.set(offsetX, -0.7, 0);
          mesh.userData.index = i;
          group.add(mesh);
          letterMeshes.push(mesh);
        }
        offsetX += charWidths[i] + CHAR_GAP;
      });

      scene.add(group);

      const startTime = performance.now();

      (function animate() {
        requestAnimationFrame(animate);
        const t = (performance.now() - startTime) / 1000;

        group.rotation.y = Math.sin(t * 0.5) * 0.4;

        letterMeshes.forEach((mesh, i) => {
          mesh.position.y = -0.7 + Math.sin(t * 2.5 + i * 0.25) * 0.3;
          (mesh.material as THREE.MeshPhongMaterial).color.setHSL(
            ((t * 0.1) + (i / text.length)) % 1,
            0.9,
            0.55,
          );
        });

        renderer.render(scene, camera);
      })();
    });

    window.addEventListener('resize', () => {
      const w = container.offsetWidth || window.innerWidth;
      camera.aspect = w / HEIGHT;
      camera.updateProjectionMatrix();
      renderer.setSize(w, HEIGHT);
    });
  }

  // Run after full layout is painted so container.offsetWidth is reliable
  if (document.readyState === 'complete') {
    init();
  } else {
    window.addEventListener('load', init);
  }
</script>


<script>
  const clock = document.getElementById('clock');

  function updateClock() {
    const now = new Date();
    const h = String(now.getHours()).padStart(2, '0');
    const m = String(now.getMinutes()).padStart(2, '0');
    const s = String(now.getSeconds()).padStart(2, '0');
    if (clock) clock.innerText = `${h}:${m}:${s}`;
  }

  updateClock();
  setInterval(updateClock, 1000);
</script>

<style>
  #title-container {
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
    height: 100px;
  }

  #title-canvas {
    display: block;
  }

  #clock {
    position: absolute;
    top: 50%;
    right: 24px;
    transform: translateY(-50%);
    font-family: 'Courier New', monospace;
    font-size: 2rem;
    font-weight: bold;
    letter-spacing: 0.1em;
    background: linear-gradient(90deg, #00ffcc, #0099ff, #cc00ff);
    background-size: 200% 100%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: clock-shift 3s linear infinite;
    text-shadow: none;
    filter: drop-shadow(0 0 8px #00ffcc88);
    pointer-events: none;
  }

  @keyframes clock-shift {
    0%   { background-position: 0% 50%; }
    100% { background-position: 200% 50%; }
  }
</style>
